# Google OAuth Client ID — create one at https://console.cloud.google.com/
# Add your domain to "Authorized JavaScript origins" in the credential settings
VITE_GOOGLE_CLIENT_ID=

# xAPI / LRS (dev/sandbox only — credentials are embedded in the client bundle)
# Phase 2: move LRS credentials to a server-side proxy; do not ship secrets in production builds.
VITE_LRS_URL=https://your-lrs.example.com/xapi/statements
VITE_LRS_USERNAME=
VITE_LRS_SECRET=
VITE_XAPI_ACTIVITY_BASE=https://your-domain.example/activities
# When true, all xAPI statements use a session-scoped pseudonymous actor (no mbox), even for signed-in users.
VITE_XAPI_PSEUDOANON=false
