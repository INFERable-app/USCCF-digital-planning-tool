# Gateway port
PORT=3001

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-32-plus-character-string

# Google OAuth — server-side only, do NOT prefix with VITE_
# Use the same Client ID as the frontend; rotate the secret from .env.local (it was exposed)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# Neo4j — only required when GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# 'stub' reads docs/wizardGraph.json; 'neo4j' connects to Neo4j
GRAPH_BACKEND=stub

# Allowed CORS origin (Vite dev server)
WEB_ORIGIN=http://localhost:5173
